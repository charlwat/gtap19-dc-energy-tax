verbal description = "Energy tax on datacenter sector - 10pct shock (crypto-to-DC + EU + hubs) on energy inputs to Information";
file GTAPSETS = sets.har ;
file GTAPDATA = basedata.har ;
file GTAPPARM = default.prm ;
Updated file GTAPDATA = dc_etax_10pct.upd ;
Method = Gragg;
Steps = 2 4 6 ;
subintervals = 4 ;
start with mmnz = 15071024 ;
Exogenous
  pop psaveslack pfactwld profitslack incomeslack endwslack
  cgdslack tradslack ams atm atf ats atd
  aosec aoreg aoall afall afcom afsec afreg
  au dppriv dpgov dpsave
  to tp tm tms tx txs
  tfd tfm tgd tgm tpd tpm
  del_ctgshr
  pemp
  RCTAXB
  qo(ENDW_COMM,REG) ;
Rest Endogenous ;

! ============================================================
! DATACENTER ENERGY TAX EXPERIMENT
! 5% tax on energy inputs (domestic + imported) to Information
! sector in EU member states + major datacenter hub countries
! Energy inputs: Electricity, Coal, Oil, Gas, Oil_Pcts
! ============================================================

! --- EU member states ---
! Electricity input tax (domestic purchases)
shock tfd("Electricity","Information","AUT") = 10.0 ;
shock tfd("Electricity","Information","BEL") = 10.0 ;
shock tfd("Electricity","Information","BGR") = 10.0 ;
shock tfd("Electricity","Information","HRV") = 10.0 ;
shock tfd("Electricity","Information","CYP") = 10.0 ;
shock tfd("Electricity","Information","CZE") = 10.0 ;
