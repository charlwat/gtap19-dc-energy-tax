shock tfd("Electricity","Information","GRC") = 10.0 ;
shock tfd("Electricity","Information","HUN") = 10.0 ;
shock tfd("Electricity","Information","IRL") = 10.0 ;
shock tfd("Electricity","Information","ITA") = 10.0 ;
shock tfd("Electricity","Information","LVA") = 10.0 ;
shock tfd("Electricity","Information","LTU") = 10.0 ;
shock tfd("Electricity","Information","LUX") = 10.0 ;
shock tfd("Electricity","Information","MLT") = 10.0 ;
shock tfd("Electricity","Information","NLD") = 10.0 ;
shock tfd("Electricity","Information","POL") = 10.0 ;
shock tfd("Electricity","Information","PRT") = 10.0 ;
shock tfd("Electricity","Information","ROU") = 10.0 ;
shock tfd("Electricity","Information","SVK") = 10.0 ;
shock tfd("Electricity","Information","SVN") = 10.0 ;
shock tfd("Electricity","Information","ESP") = 10.0 ;
shock tfd("Electricity","Information","SWE") = 10.0 ;

