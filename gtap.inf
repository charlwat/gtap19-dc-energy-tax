   4733   (all,r,REG)
   4734       CNTqpmr(r)
   4735           = sum(i,TRAD_COMM,
   4736               [IPTAX(i,r) + IPCTAX(i,r)] * [0.01 * EVSCALFACT(r)]
   4737                   * [qpm(i,r) - pop(r)]);
   4738    
   4739   Variable (linear,change) (all,i,TRAD_COMM)(all,r,REG)
   4740       CNTqpmir(i,r)
   4741       # cont. to EV of changes in consumption of imported good i in reg. r #;
   4742   Equation CONT_EV_qpmir
   4743   (all,i,TRAD_COMM)(all,r,REG)
   4744       CNTqpmir(i,r)
   4745           = [IPTAX(i,r) + IPCTAX(i,r)] * [0.01 * EVSCALFACT(r)]
   4746               * [qpm(i,r) - pop(r)];
   4747    
   4748   Variable (linear,change) (all,r,REG)
   4749       CNTqpdr(r)
   4750       # contribution to EV of changes in consumption of domestic goods in r #;
   4751   Equation CONT_EV_qpdr
   4752   (all,r,REG)
   4753       CNTqpdr(r)
   4754           = sum(i,TRAD_COMM,
   4755               [DPTAX(i,r) + DPCTAX(i,r)] * [0.01 * EVSCALFACT(r)]
   4756                   * [qpd(i,r) - pop(r)]);
   4757    
   4758   Variable (linear,change) (all,i,TRAD_COMM)(all,r,REG)
   4759       CNTqpdir(i,r)
   4760       # cont. to EV of changes in consumption of domestic good i in reg. r #;
   4761   Equation CONT_EV_qpdir
   4762   (all,i,TRAD_COMM)(all,r,REG)
   4763       CNTqpdir(i,r)
   4764           = [DPTAX(i,r) + DPCTAX(i,r)] * [0.01 * EVSCALFACT(r)]
   4765               * [qpd(i,r) - pop(r)];
   4766    
   4767   Variable (linear,change) (all,r,REG)
   4768       CNTqgmr(r)
   4769       # cont. to EV of changes in gov't consumption of imports in reg. r #;
   4770   Equation CONT_EV_qgmr
   4771   (all,r,REG)
   4772       CNTqgmr(r)
   4773           = sum(i,TRAD_COMM,
   4774               [IGTAX(i,r) + IGCTAX(i,r)] * [0.01 * EVSCALFACT(r)]
   4775                   * [qgm(i,r) - pop(r)]);
   4776    
   4777   Variable (linear,change) (all,i,TRAD_COMM)(all,r,REG)
   4778       CNTqgmir(i,r)
   4779       # cont. to EV of changes in gov't consumption of import i in reg. r #;
   4780   Equation CONT_EV_qgmir
   4781   (all,i,TRAD_COMM)(all,r,REG)
   4782       CNTqgmir(i,r)
   4783           = [IGTAX(i,r) + IGCTAX(i,r)] * [0.01 * EVSCALFACT(r)]
   4784               * [qgm(i,r) - pop(r)];
   4785    
   4786   Variable (linear,change) (all,r,REG)
   4787       CNTqgdr(r)
   4788       # cont. to EV of changes in gov't consumption of domestics in reg. r #;
   4789   Equation CONT_EV_qgdr
   4790   (all,r,REG)
   4791       CNTqgdr(r)
   4792           = sum(i,TRAD_COMM,
   4793               [DGTAX(i,r) + DGCTAX(i,r)] * [0.01 * EVSCALFACT(r)]
   4794                   * [qgd(i,r) - pop(r)]);
   4795    
   4796   Variable (linear,change) (all,i,TRAD_COMM)(all,r,REG)
   4797       CNTqgdir(i,r)
   4798       # cont. to EV of changes in gov't consumption of domestic i in reg. r #;
   4799   Equation CONT_EV_qgdir
   4800   (all,i,TRAD_COMM)(all,r,REG)
   4801       CNTqgdir(i,r)
   4802           = [DGTAX(i,r) + DGCTAX(i,r)] * [0.01 * EVSCALFACT(r)]
   4803               * [qgd(i,r) - pop(r)];
   4804    
   4805   Variable (linear,change) (all,r,REG)
   4806       CNTqxsr(r)
   4807       # cont. to EV of changes in exports of all goods from SRCE r to all DEST #;
   4808   Equation CONT_EV_qxsr
   4809   (all,r,REG)
   4810       CNTqxsr(r)
   4811           = sum(i,TRAD_COMM, sum(s,REG,
   4812               XTAXD(i,r,s) * [0.01 * EVSCALFACT(r)] * [qxs(i,r,s) - pop(r)]));
   4813    
   4814   Variable (linear,change) (all,i,TRAD_COMM)(all,r,REG)(all,s,REG)
   4815       CNTqxsirs(i,r,s)
   4816       # cont. to EV of changes in exports of i from SRCE r to DEST s #;
   4817   Equation CONT_EV_qxsirs
   4818   (all,i,TRAD_COMM)(all,r,REG)(all,s,REG)
   4819       CNTqxsirs(i,r,s)
   4820           = XTAXD(i,r,s) * [0.01 * EVSCALFACT(r)] * [qxs(i,r,s) - pop(r)];
   4821    
   4822   Variable (linear,change) (all,r,REG)
   4823       CNTqimr(r)
   4824       # cont. to EV of changes in imports of all goods from all SRCE to DEST r #;
   4825   Equation CONT_EV_qimr
   4826   (all,r,REG)
   4827       CNTqimr(r)
   4828           = sum(i,TRAD_COMM, sum(s,REG,
   4829               MTAX(i,s,r) * [0.01 * EVSCALFACT(r)] * [qxs(i,s,r) - pop(r)]));
   4830    
   4831   Variable (linear,change) (all,i,TRAD_COMM)(all,s,REG)(all,r,REG)
   4832       CNTqimisr(i,s,r)
   4833       # cont. to EV of changes in imports of i from SRCE s to DEST r #;
   4834   Equation CONT_EV_qimisr
   4835   (all,i,TRAD_COMM)(all,s,REG)(all,r,REG)
   4836       CNTqimisr(i,s,r)
   4837           = MTAX(i,s,r) * [0.01 * EVSCALFACT(r)] * [qxs(i,s,r) - pop(r)];
   4838    
   4839   Variable (linear,change) (all,r,REG)
   4840       CNTalleffr(r) # total contribution to regional EV of allocative effects #;
   4841   Equation CONT_EV_alleffr
   4842   (all,r,REG)
   4843       CNTalleffr(r)
   4844           = [0.01 * EVSCALFACT(r)]
   4845           * [sum(i,NSAV_COMM, PTAX(i,r) * [qo(i,r) - pop(r)])
   4846               + sum(i,ENDW_COMM, sum(j,PROD_COMM,
   4847                   ETAX(i,j,r) * [qfe(i,j,r) - pop(r)]))
   4848               + sum(j,PROD_COMM, sum(i,TRAD_COMM,
   4849                   [IFTAX(i,j,r) + IFCTAX(i,j,r)] *  [qfm(i,j,r) - pop(r)]))
   4850               + sum(j,PROD_COMM, sum(i,TRAD_COMM,
   4851                   [DFTAX(i,j,r) + DFCTAX(i,j,r)] *  [qfd(i,j,r) - pop(r)]))
   4852               + sum(i,TRAD_COMM,
   4853                   [IPTAX(i,r) + IPCTAX(i,r)] * [qpm(i,r) - pop(r)])
   4854               + sum(i,TRAD_COMM,
   4855                   [DPTAX(i,r) + DPCTAX(i,r)] * [qpd(i,r) - pop(r)])
   4856               + sum(i,TRAD_COMM,
   4857                   [IGTAX(i,r) + IGCTAX(i,r)] * [qgm(i,r) - pop(r)])
   4858               + sum(i,TRAD_COMM,
   4859                   [DGTAX(i,r) + DGCTAX(i,r)] * [qgd(i,r) - pop(r)])
   4860               + sum(i,TRAD_COMM, sum(s,REG, XTAXD(i,r,s) * [qxs(i,r,s) - pop(r)]))
   4861               + sum(i,TRAD_COMM, sum(s,REG,
   4862                   MTAX(i,s,r) * [qxs(i,s,r) - pop(r)]))];
   4863    
   4864   Variable (linear,change) (all,i,DEMD_COMM)(all,r,REG)
   4865       CNTalleffir(i,r)
   4866       # total contribution to regional EV of allocative effects #;
   4867   Equation CONT_EV_alleffir_E
   4868   (all,i,ENDW_COMM)(all,r,REG)
   4869       CNTalleffir(i,r)
   4870           = [0.01 * EVSCALFACT(r)]
   4871           * [PTAX(i,r) * [qo(i,r) - pop(r)]
   4872               + sum(j,PROD_COMM, ETAX(i,j,r) * [qfe(i,j,r) - pop(r)])];
   4873   Equation CONT_EV_alleffir_T
   4874   (all,i,TRAD_COMM)(all,r,REG)
   4875       CNTalleffir(i,r)
   4876           = [0.01 * EVSCALFACT(r)]
   4877           * [PTAX(i,r) * [qo(i,r) - pop(r)]
   4878               + sum(j,PROD_COMM, [IFTAX(i,j,r) + IFCTAX(i,j,r)]
   4879                   * [qfm(i,j,r) - pop(r)])
   4880               + sum(j,PROD_COMM, [DFTAX(i,j,r) + DFCTAX(i,j,r)]
   4881                   * [qfd(i,j,r) - pop(r)])
   4882               + [IPTAX(i,r) + IPCTAX(i,r)] * [qpm(i,r) - pop(r)]
   4883               + [DPTAX(i,r) + DPCTAX(i,r)] * [qpd(i,r) - pop(r)]
   4884               + [IGTAX(i,r) + IGCTAX(i,r)] * [qgm(i,r) - pop(r)]
   4885               + [DGTAX(i,r) + DGCTAX(i,r)] * [qgd(i,r) - pop(r)]
   4886               + sum(s,REG, XTAXD(i,r,s) * [qxs(i,r,s) - pop(r)])
   4887               + sum(s,REG, MTAX(i,s,r) * [qxs(i,s,r) - pop(r)])];
   4888    
   4889   Variable (linear,change) (all,r,REG)
   4890       CNTtotr(r)
   4891       # contribution to regional EV of changes in its terms of trade #;
   4892   Equation CONT_EV_totr
   4893   (all,r,REG)
   4894       CNTtotr(r)
   4895           = [0.01 * EVSCALFACT(r)]
   4896           * [sum(i,TRAD_COMM, sum(s,REG, VXWD(i,r,s) * [pfob(i,r,s) - pxwwld]))
   4897               + sum(m,MARG_COMM, VST(m,r) * [pm(m,r) - pxwwld])
   4898               - sum(i,TRAD_COMM, sum(s,REG, VXWD(i,s,r) * [pfob(i,s,r) - pxwwld]))
   4899               - sum(m,MARG_COMM, VTMD(m,r) * [pt(m) - pxwwld])];
   4900    
   4901   Variable (linear,change) (all,r,REG)
   4902       CNTcgdsr(r) # contribution to regional EV of changes in the price of cgds #;
   4903   Equation CNT_EV_cgdsr
   4904   (all,r,REG)
   4905       CNTcgdsr(r)
   4906           = [0.01 * EVSCALFACT(r)]
   4907           * [NETINV(r) * [pcgds(r) - pxwwld] - SAVE(r) * [psave(r) - pxwwld]];
   4908    
   4909   Variable (linear,change) (all,r,REG)
   4910       CNTendwr(r) # contribution to regional EV of changes in all ENDW_COMM #;
   4911   Equation CONT_EV_endwr
   4912   (all,r,REG)
   4913       CNTendwr(r)
   4914           = [0.01 * EVSCALFACT(r)]
   4915           * [sum(i,ENDW_COMM, VOA(i,r) * [qo(i,r) - pop(r)])
   4916               - VDEP(r) * [kb(r) - pop(r)]];
   4917    
   4918   Variable (linear,change) (all,i,ENDW_COMM)(all,r,REG)
   4919       CNTendwir(i,r) # contribution to regional EV of changes in ENDW_COMM i #;
   4920   Equation CONT_EV_endwir
   4921   (all,i,ENDW_COMM)(all,r,REG)
   4922       CNTendwir(i,r) = [0.01 * EVSCALFACT(r)] * [VOA(i,r) * [qo(i,r) - pop(r)]];
   4923    
   4924   Variable (linear,change) (all,r,REG)
   4925       CNTtechr(r) # contribution to regional EV of all technical change #;
   4926   Equation CONT_EV_techr
   4927   (all,r,REG)
   4928       CNTtechr(r)
   4929           = [0.01 * EVSCALFACT(r)]
   4930           * [sum(i,PROD_COMM, VOA(i,r) * ao(i,r))
   4931               + sum(j,PROD_COMM, sum(i,FIRM_COMM, VFA(i,j,r) * af(i,j,r)))
   4932               + sum(m,MARG_COMM, sum(i,TRAD_COMM, sum(s,REG,
   4933                   VTMFSD(m,i,s,r) * atmfsd(m,i,s,r))))
   4934               + sum(i,TRAD_COMM, sum(s,REG, VIMS(i,s,r) * ams(i,s,r)))];
   4935    
   4936   Variable (linear,change) (all,r,REG)
   4937       CNTtech_aor(r)
   4938       # contribution to regional EV of output augmenting technical change #;
   4939   Equation CONT_EV_tech_aor
   4940   (all,r,REG)
   4941       CNTtech_aor(r)
   4942           = [0.01 * EVSCALFACT(r)] * sum(i,PROD_COMM, VOA(i,r) * ao(i,r));
   4943    
   4944   Variable (linear,change) (all,i,PROD_COMM)(all,r,REG)
   4945       CNTtech_aoir(i,r)
   4946       # cont. to regional EV of output augmenting tech change in TRAD_COMM i #;
   4947   Equation CONT_EV_tech_aoir
   4948   (all,i,PROD_COMM)(all,r,REG)
   4949       CNTtech_aoir(i,r) = [0.01 * EVSCALFACT(r)] * VOA(i,r) * ao(i,r);
   4950    
   4951   Variable (linear,change) (all,r,REG)
   4952       CNTtech_afr(r)
   4953       # cont. to regional EV of input augmenting tech change #;
   4954   Equation CONT_EV_tech_afr
   4955   (all,r,REG)
   4956       CNTtech_afr(r)
   4957           = [0.01 * EVSCALFACT(r)]
   4958           * sum(j,PROD_COMM, sum(i,FIRM_COMM, VFA(i,j,r) * af(i,j,r)));
   4959    
   4960   Variable (linear,change) (all,i,FIRM_COMM)(all,j,PROD_COMM)(all,r,REG)
   4961       CNTtech_afijr(i,j,r)
   4962       # cont. to EV of input i input augmenting tech change in sector j #;
   4963   Equation CONT_EV_tech_afijr
   4964   (all,i,FIRM_COMM)(all,j,PROD_COMM)(all,r,REG)
   4965       CNTtech_afijr(i,j,r) = [0.01 * EVSCALFACT(r)] * VFA(i,j,r) * af(i,j,r);
   4966    
   4967   Variable (linear,change) (all,r,REG)
   4968       CNTtech_atrr(r)
   4969       # contribution to regional EV of technical change in transportation #;
   4970   Equation CONT_EV_tech_atrr
   4971   (all,r,REG)
   4972       CNTtech_atrr(r)
   4973           = [0.01 * EVSCALFACT(r)]
   4974           * sum(m,MARG_COMM, sum(i,TRAD_COMM, sum(s,REG,
   4975               VTMFSD(m,i,s,r) * atmfsd(m,i,s,r))));
   4976    
   4977   Variable (linear,change)(all,m,MARG_COMM)(all,i,TRAD_COMM)(all,r,REG)(all,s,REG)
   4978       CNTtech_afmfdsd(m,i,r,s)
   4979       # cont. to EV of tech change in transportation efficiency #;
   4980   Equation CONT_EV_tech_afmfdsd
   4981   (all,m,MARG_COMM)(all,i,TRAD_COMM)(all,r,REG)(all,s,REG)
   4982       CNTtech_afmfdsd(m,i,r,s)
   4983           = [0.01 * EVSCALFACT(s)] * VTMFSD(m,i,r,s) * atmfsd(m,i,r,s);
   4984    
   4985   Variable (linear,change)(all,r,REG)
   4986       CNTtech_amsr(r) # cont. to EV of bilateral import-augmenting tech change #;
   4987   Equation CONT_EV_tech_amsr
   4988   (all,r,REG)
   4989       CNTtech_amsr(r)
   4990           = [0.01 * EVSCALFACT(r)]
   4991           * sum(i,TRAD_COMM, sum(s,REG, VIMS(i,s,r) * ams(i,s,r)));
   4992    
   4993   Variable (linear,change) (all,i,TRAD_COMM)(all,r,REG)(all,s,REG)
   4994       CNTtech_amsirs(i,r,s)
   4995    # cont. to EV of bilateral import augmenting tech change for TRAD_COMM i #;
   4996   Equation CONT_EV_tech_amsirs
   4997   (all,i,TRAD_COMM)(all,r,REG)(all,s,REG)
   4998       CNTtech_amsirs(i,r,s) = [0.01 * EVSCALFACT(r)] * VIMS(i,r,s) * ams(i,r,s);
   4999    
   5000   Variable (linear,change) (all,r,REG)
   5001       CNTkbr(r)
   5002       # cont. to EV of changes to beg. period capital stock and depreciation #;
   5003   Equation CONT_EV_kbr
   5004   (all,r,REG)
   5005       CNTkbr(r) = - [0.01 * EVSCALFACT(r)] * VDEP(r) * [kb(r) - pop(r)];
   5006    
   5007    
   5008   !<
   5009       -------------------------------
   5010       D. Terms of Trade Decomposition
   5011       -------------------------------
   5012    
   5013       Computations for decomposition the terms-of-trade effect
   5014       Reference: Robert McDougall, SALTER No. 12 Working Paper
   5015   >!
   5016    
   5017   Coefficient (all,i,TRAD_COMM)(all,r,REG)
   5018       SX_IR(i,r) # share of good i in total exports from r #;
   5019   Formula (all,m,MARG_COMM)(all,r,REG)
   5020       SX_IR(m,r)
   5021           = [sum(s,REG, VXWD(m,r,s)) + VST(m,r)]
   5022           / [sum(k,TRAD_COMM, sum(s,REG, VXWD(k,r,s)))
   5023               + sum(l,MARG_COMM, VST(l,r))];
   5024   Formula (all,i,NMRG_COMM)(all,r,REG)
   5025       SX_IR(i,r)
   5026           = sum(s,REG, VXWD(i,r,s))
   5027           / [sum(k,TRAD_COMM, sum(s,REG, VXWD(k,r,s)))
   5028               + sum(l,MARG_COMM, VST(l,r))];
   5029    
   5030   Coefficient (all,m,MARG_COMM)(all,s,REG)
   5031       VTICOMM(m,s) # margin usage of m in getting imports to region s #;
   5032   Formula (all,m,MARG_COMM)(all,s,REG)
   5033       VTICOMM(m,s) = sum(i,TRAD_COMM, sum(r,REG, VTMFSD(m,i,r,s)));
   5034    
   5035   Coefficient (all,i,TRAD_COMM)(all,s,REG)
   5036       VIWDIRALL(i,s) # imports of i into s, with direct allocation of margins #;
   5037   Formula (all,m,MARG_COMM)(all,s,REG)
   5038       VIWDIRALL(m,s) = sum(r,REG, VXWD(m,r,s)) + VTICOMM(m,s);
   5039   Formula (all,i,NMRG_COMM)(all,s,REG)
   5040       VIWDIRALL(i,s) = sum(r,REG, VXWD(i,r,s));
   5041    
   5042   Coefficient (all,s,REG)
   5043       VIWDATOT(s) # total imports into s, calculated on direct allocation basis #;
   5044   Formula (all,s,REG)
   5045       VIWDATOT(s) = sum(i,TRAD_COMM, VIWDIRALL(i,s));
   5046    
   5047   Coefficient (all,i,TRAD_COMM)(all,r,REG)
   5048       SM_IR(i,r)  # share of good i in total imports into r #;
   5049   Formula (all,i,TRAD_COMM)(all,s,REG)
   5050       SM_IR(i,s) = VIWDIRALL(i,s) / VIWDATOT(s);
   5051    
   5052   Zerodivide (zero_by_zero) default 0;
   5053   Coefficient (all,i,TRAD_COMM)(all,r,REG)(all,s,REG)
   5054       SX_IRS(i,r,s) # share of exports of good i from region r to s #;
   5055   Formula (all,m,MARG_COMM)(all,r,REG)(all,s,REG)
   5056       SX_IRS(m,r,s) = VXWD(m,r,s) / [sum(k,REG, VXWD(m,r,k)) + VST(m,r)];
   5057   Formula (all,i,NMRG_COMM)(all,r,REG)(all,s,REG)
   5058       SX_IRS(i,r,s) = VXWD(i,r,s) / sum(k,REG, VXWD(i,r,k));
   5059   Zerodivide (zero_by_zero) off;
   5060    
   5061   Coefficient (all,m,MARG_COMM)(all,r,REG)
   5062       SXT_IR(m,r) # share of margins in exports of good i from region r #;
   5063   Formula (all,m,MARG_COMM)(all,r,REG)
   5064       SXT_IR(m,r) = VST(m,r) / [sum(k,REG, VXWD(m,r,k)) + VST(m,r)];
   5065    
   5066   Variable (all,i,TRAD_COMM)(all,r,REG)
   5067       px_ir(i,r) # export price index for good i and region r #;
   5068   Equation EXPPRICE_MARG
   5069   # price index for total exports of m from r #
   5070   (all,m,MARG_COMM)(all,r,REG)
   5071       px_ir(m,r)
   5072           = sum(s,REG, SX_IRS(m,r,s) * pfob(m,r,s)) + SXT_IR(m,r) * pm(m,r);
   5073   Equation EXPPRICE_NMRG
   5074   # price index for total exports of i from r #
   5075   (all,i,NMRG_COMM)(all,r,REG)
   5076       px_ir(i,r) = sum(s,REG, SX_IRS(i,r,s) * pfob(i,r,s));
   5077    
   5078   Coefficient (all,i,TRAD_COMM)(all,r,REG)(all,s,REG)
   5079       SM_IRS(i,r,s) # share of imports of good i into s from r at FOB prices #;
   5080   Formula (all,i,TRAD_COMM)(all,r,REG)(all,s,REG)
   5081       SM_IRS(i,r,s) = VXWD(i,r,s) / VIWDIRALL(i,s);
   5082    
   5083   Coefficient (all,m,MARG_COMM)(all,r,REG)
   5084       SMT_IR(m,r) # share of transport cost in imports of margin commodity #;
   5085   Formula (all,m,MARG_COMM)(all,s,REG)
   5086       SMT_IR(m,s) = VTICOMM(m,s) / VIWDIRALL(m,s);
   5087    
   5088   Variable (all,i,TRAD_COMM)(all,r,REG)
   5089       pm_ir(i,r) # imports price index for good i and region r #;
   5090   Equation IMPPRICE1_MARG
   5091   # price index for total imports of m in s -- margins commodities #
   5092   (all,m,MARG_COMM)(all,s,REG)
   5093       pm_ir(m,s)
   5094           = sum(r,REG, SM_IRS(m,r,s) * pfob(m,r,s)) + SMT_IR(m,s) * pt(m);
   5095   Equation IMPPRICE1_NMRG
   5096   # price index for total imports of i in s -- non-margins commodities #
   5097   (all,i,NMRG_COMM)(all,s,REG)
   5098       pm_ir(i,s) = sum(r,REG, SM_IRS(i,r,s) * pfob(i,r,s));
   5099    
   5100   Coefficient (all,i,TRAD_COMM)(all,r,REG)
   5101       SW_IR(i,r) # share of region r exports in world total for good i #;
   5102   Formula (all,m,MARG_COMM)(all,r,REG)
   5103       SW_IR(m,r)
   5104           = [sum(s,REG, VXWD(m,r,s)) + VST(m,r)]
   5105           / sum(k,REG, sum(s,REG, VXWD(m,k,s)) + VST(m,k));
   5106   Formula (all,i,NMRG_COMM)(all,r,REG)
   5107       SW_IR(i,r)
   5108           = sum(s,REG, VXWD(i,r,s)) / sum(k,REG, sum(s,REG, VXWD(i,k,s)));
   5109    
   5110   Variable (all,i,TRAD_COMM)
   5111       px_i(i) # world export price index for commodity i #;
   5112   Equation WRLDPRICEi
   5113   # world export price index for good i #
   5114   (all,i,TRAD_COMM)
   5115       px_i(i) = sum(r,REG, SW_IR(i,r) * px_ir(i,r));
   5116    
   5117   Coefficient (all,i,TRAD_COMM)
   5118       SW_I(i) # share of exports of i in world total #;
   5119   Formula (all,m,MARG_COMM)
   5120       SW_I(m)
   5121           = sum(r,REG, sum(s,REG, VXWD(m,r,s)) + VST(m,r))
   5122           / [sum(k,TRAD_COMM, sum(r,REG, sum(s,REG, VXWD(k,r,s))))
   5123               + sum(l,MARG_COMM, sum(r,REG, VST(l,r)))];
   5124   Formula (all,i,NMRG_COMM)
   5125       SW_I(i)
   5126           = sum(r,REG, sum(s,REG, VXWD(i,r,s)))
   5127           / [sum(k,TRAD_COMM, sum(r,REG, sum(s,REG, VXWD(k,r,s))))
   5128               + sum(l,MARG_COMM, sum(r,REG, VST(l,r)))];
   5129    
   5130   Variable
   5131       px_ # world export price index for all commodities #;
   5132   Equation WRLDPRICE
   5133   # world export price index for all goods #
   5134       px_ = sum(i,TRAD_COMM, SW_I(i) * px_i(i));
   5135    
   5136   Variable (all,i,TRAD_COMM)(all,r,REG)
   5137       c1_ir(i,r) # contribution of world price, px_i, to ToT #;
   5138   Equation c1_irEQ
   5139   # contribution of world export price index of good i to ToT for region r #
   5140   (all,i,TRAD_COMM)(all,r,REG)
   5141       c1_ir(i,r) = [SX_IR(i,r) - SM_IR(i,r)] * [px_i(i) - px_];
   5142    
   5143   Variable (all,i,TRAD_COMM)(all,r,REG)
   5144       c2_ir(i,r) # contribution of regional export price, px_ir, to ToT #;
   5145   Equation c2_irEQ
   5146   # contribution of regional export price of good i for region r #
   5147   (all,i,TRAD_COMM)(all,r,REG)
   5148       c2_ir(i,r) = SX_IR(i,r) * [px_ir(i,r) - px_i(i)];
   5149    
   5150   Variable (all,i,TRAD_COMM)(all,r,REG)
   5151       c3_ir(i,r) # contribution of regional import price, pm_ir, to ToT #;
   5152   Equation c3_irEQ
   5153   # contribution of imports price index of good i for region r #
   5154   (all,i,TRAD_COMM)(all,r,REG)
   5155       c3_ir(i,r) = SM_IR(i,r) * [pm_ir(i,r) - px_i(i)];
   5156    
   5157   Variable (all,r,REG)
   5158       c1_r(r) # contribution of world prices for all goods to ToT #;
   5159   Equation c1_rEQ
   5160   # contribution of world price indexes of all goods to ToT for r #
   5161   (all,r,REG)
   5162       c1_r(r) = sum(i,TRAD_COMM, c1_ir(i,r));
   5163    
   5164   Variable (all,r,REG)
   5165       c2_r(r) # contribution of regional export prices to ToT #;
   5166   Equation c2_rEQ
   5167   # contribution of regional exports prices to ToT for r #
   5168   (all,r,REG)
   5169       c2_r(r) = sum(i,TRAD_COMM, c2_ir(i,r));
   5170    
   5171   Variable (all,r,REG)
   5172       c3_r(r) # contribution of regional import prices to ToT #;
   5173   Equation c3_rEQ
   5174   # contribution of regional import prices to ToT for r #
   5175   (all,r,REG)
   5176       c3_r(r) = sum(i,TRAD_COMM, c3_ir(i,r));
   5177    
   5178   Variable (all,r,REG)
   5179       tot2(r) # trade terms for region r, computed from components #;
   5180   Equation TOT2eq
   5181   # trade terms for region r, computed from components #
   5182   (all,r,REG)
   5183       tot2(r) = c1_r(r) + c2_r(r) - c3_r(r);
   5184    
   5185    
   5186   !<
   5187       ====================
   5188       END OF GTAP.TAB FILE
   5189       ====================
   5190   >!
 
 
